node_modules/
.demo-dist/
*.tsbuildinfo
.DS_Store
graph-a-lama-out/

# Kern 01: WASM build artifact (not byte-stable across hosts) + Cargo's
# own build output.
*.wasm
crates/**/target/

# Kern 06: threads build uses a SEPARATE --target-dir (never "target") so
# the stable build's own target/ and incremental cache are never touched —
# crates/**/target/ above does not match this name, so it needs its own line.
crates/**/target-threads/
.claude/worktrees/

# Spike 02: generated editor-latency workload files (gen-workloads.ts is the
# source of truth; `pnpm bench:editor` regenerates on every run).
spike/bench-dx/workloads/

# Scale-Probe (docs/scale-probe-spec.md, D1): generated sweep-corpus files
# (gen-scale-workloads.ts is the source of truth; `pnpm bench:scale`
# regenerates on every run) — same precedent as spike/bench-dx/workloads/
# above.
spike/bench-dx/scale-workloads/

# Item 11 / S2: dist-Build-Output (regeneriert von `pnpm build:dist`, kommt in
# den npm-Tarball via package.json "files":["dist"], NICHT committet). Die
# numtype_core.wasm darin ist schon durch die *.wasm-Regel oben erfasst.
/dist/

# V3 (Browser-Smoke-Test): tsc-emitted scratch tree (test:browser regenerates
# on every run; *.wasm inside it is already covered by the rule above) +
# Playwright's own report/output directories.
spike/tests-browser/.emit/
playwright-report/
test-results/
blob-report/
playwright/.cache/

# Item 13 (Release-Vorbereitung): HANDOFF.md ist reiner Session-Zustand des
# Maintainer-Workflows — bleibt lokal erhalten und in Benutzung, gehört aber
# nicht ins (bald öffentliche) Repo. Entfernt aus dem Index via
# `git rm --cached HANDOFF.md` (Datei bleibt auf der Platte).
HANDOFF.md
